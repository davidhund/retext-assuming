{
	"name": "retext-assuming",
	"version": "2.0.0",
	"description": "Check for unhelpful ‘assuming’ phrases such as ‘just’, ‘simply’ or ‘obviously’ with retext",
	"type": "module",
	"exports": "./index.js",
	"scripts": {
		"pretest": "npm run lint",
		"test": "tape test.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"keywords": [
		"retext",
		"plugin",
		"phrase",
		"unhelpful",
		"documentation",
		"inclusive"
	],
	"author": "David Hund <david@valuedstandards.com> (https://valuedstandards.com)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/davidhund/retext-assuming.git"
	},
	"bugs": "https://github.com/davidhund/retext-assuming/issues",
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"files": [
		"index.js",
		"phrases.json"
	],
	"dependencies": {
		"lodash.difference": "4.5.0",
		"nlcst-search": "4.0.0",
		"nlcst-to-string": "4.0.0",
		"quotation": "2.0.3",
		"unist-util-find-before": "4.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"retext": "9.0.0",
		"tape": "5.10.2",
		"to-vfile": "8.0.0",
		"vfile-reporter": "8.1.1"
	}
}
